FROM alpine:3.20

RUN apk add --no-cache \
    openssh-server \
    postgresql16-client \
    git \
    bash \
    ca-certificates \
    nodejs \
    npm

# Generate SSH host keys
RUN ssh-keygen -A

# Setup directories
RUN mkdir -p /var/run/sshd /root/.ssh /workspaces /data/home \
    && chmod 700 /root/.ssh

# Install agent tools
ARG OPENCODE_VERSION=1.1.4
ARG CLAUDECODE_VERSION=2.1.116
RUN npm install -g "opencode-ai@${OPENCODE_VERSION}" \
    && npm install -g "@anthropic-ai/claude-code@${CLAUDECODE_VERSION}"

# Copy scripts
COPY scripts/ /usr/local/bin/akama-scripts/
RUN chmod +x /usr/local/bin/akama-scripts/*.sh

# Copy worker entrypoint
COPY scripts/worker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/worker-entrypoint.sh

# Expose SSH port
EXPOSE 22

# Start with entrypoint that handles env vars
ENTRYPOINT ["/usr/local/bin/worker-entrypoint.sh"]
