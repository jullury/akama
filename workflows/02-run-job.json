    {
      "parameters": {
        "jsCode": "// Build prompt and write to temp file\nconst job = $('Read Job').item.json;\nconst body = (job.issue_body || '').substring(0, 8000);\nconst prompt = `You are fixing an issue in the current repository.\\n\\nIssue Title: ${job.issue_title}\\nIssue URL: ${job.repo_url.replace('.git', '')}/issues/${job.issue_id}\\n\\nDescription:\\n${body}\\n\\nInstructions:\\n- Read the codebase to understand the context.\\n- Implement the minimal fix for this issue.\\n- Commit all changes with a descriptive message.\\n- Do NOT open pull requests — just commit.`;\n\nconst fs = require('fs');\nconst path = `/tmp/prompt-${job.id}.txt`;\nfs.writeFileSync(path, prompt);\nreturn [{ prompt_path: path, job_id: job.id }];"
      },
      "id": "write-prompt",
      "name": "Write Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "command": "=/usr/local/bin/akama-scripts/run-agent.sh {{ $('Read Job').item.json.agent }} {{ $('Read Job').item.json.agent_model }} /workspaces/{{ $('Read Job').item.json.id }} {{ $json.prompt_path }}"
      },
      "id": "run-agent",
      "name": "Run Agent",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [1780, 300],
      "onError": "continueErrorOutput",
      "credentials": {
        "sshPassword": { "id": "3", "name": "Worker SSH" }
      }
    },
    {
      "parameters": {
        "command": "=/usr/local/bin/akama-scripts/git-commit-push.sh /workspaces/{{ $('Read Job').item.json.id }} akama/issue-{{ $('Read Job').item.json.issue_id }} {{ $('Read Job').item.json.git_token }}"
      },
      "id": "git-push",
      "name": "Git Commit Push",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [1780, 540],
      "credentials": {
        "sshPassword": { "id": "3", "name": "Worker SSH" }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false, "leftValue": "={{ $('Read Job').item.json.repo_url }}", "operation": "contains", "rightValue": "github.com" }
        }
      },
      "id": "check-provider",
      "name": "Check Git Provider",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2000, 540]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.github.com/repos/{{ $('Read Job').item.json.repo_url.replace('https://github.com/', '').replace('.git', '') }}/pulls",
        "authentication": "githubApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"title\": \"fix: {{ $('Read Job').item.json.issue_title }}\",\n  \"head\": \"akama/issue-{{ $('Read Job').item.json.issue_id }}\",\n  \"base\": \"main\",\n  \"body\": \"Automated fix for issue #{{ $('Read Job').item.json.issue_id }}\"\n}",
        "options": {}
      },
      "id": "create-github-pr",
      "name": "Create GitHub PR",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2220, 440]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://gitlab.com/api/v4/projects/{{ $encodeURIComponent($('Read Job').item.json.repo_url.replace('https://gitlab.com/', '').replace('.git', '')) }}/merge_requests",
        "authentication": "gitlabApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"title\": \"fix: {{ $('Read Job').item.json.issue_title }}\",\n  \"source_branch\": \"akama/issue-{{ $('Read Job').item.json.issue_id }}\",\n  \"target_branch\": \"main\",\n  \"description\": \"Automated fix for issue #{{ $('Read Job').item.json.issue_id }}\"\n}",
        "options": {}
      },
      "id": "create-gitlab-mr",
      "name": "Create GitLab MR",
      "type": "n8n-nodes-base.httpRequest",
