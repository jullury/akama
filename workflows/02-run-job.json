      "position": [2220, 640]
    },
    {
      "parameters": {
        "jsCode": "// Normalize PR/MR response to common format\nconst github = $('Create GitHub PR').item?.json;\nconst gitlab = $('Create GitLab MR').item?.json;\nconst pr_url = github?.html_url || gitlab?.web_url || '';\nreturn [{ pr_url }];"
      },
      "id": "normalize-pr",
      "name": "Normalize PR URL",
      "type": "n8n-nodes-base.code",
