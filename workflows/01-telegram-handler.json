    {
      "parameters": {
        "jsCode": "const chatId = $('Telegram Trigger').item.json.message.chat.id;\nreturn { chat_id: chatId, state: 'await_provider', data: {} };"
      },
      "id": "set-state-connect",
      "name": "Set State await_provider",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
        220
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO akama_conversations (chat_id, platform, state, data, updated_at) VALUES ($1, 'telegram', 'await_provider', '{}', NOW()) ON CONFLICT (chat_id, platform) DO UPDATE SET state = 'await_provider', data = '{}', updated_at = NOW()",
        "parameters": [
          {
            "position": 1,
            "value": "={{ $json.chat_id }}"
          }
        ]
      },
      "id": "save-state-connect",
      "name": "Save Connect State",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        1140,
        220
      ],
      "credentials": {
        "postgres": {
          "id": "1",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT * FROM akama_conversations WHERE chat_id = {{ $json.message.chat.id }} AND platform = 'telegram'"
      },
