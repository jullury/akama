    {
      "parameters": {
        "chatId": "={{ $json.message.chat.id }}",
        "text": "Welcome to Akama! I'm your AI coding assistant.\n\nCommands:\n/connect \u2014 Link a repo (GitHub/GitLab/Trello)\n/connections \u2014 List connected repos\n/issues \u2014 Fetch open issues\n/status \u2014 Check recent jobs\n/done <id> \u2014 Mark job complete\n/cancel \u2014 Cancel current flow\n\nSend me a repo URL to get started, or /connect to begin."
      },
      "id": "cmd-start",
      "name": "Send Welcome",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        700,
        100
      ],
      "credentials": {
        "telegramApi": {
          "id": "2",
          "name": "Telegram account"
        }
      }
    },
 {
      "parameters": {
        "chatId": "={{ $json.message.chat.id }}",
        "text": "Choose a provider:",
        "additionalFields": {
          "replyMarkup": "inlineKeyboard",
          "inlineKeyboard": {
            "rows": [
              {
                "buttons": [
                  {
                    "text": "GitHub",
                    "callback_data": "connect:github"
                  },
                  {
                    "text": "GitLab",
                    "callback_data": "connect:gitlab"
                  }
                ]
              }
            ]
          }
        }
      },
