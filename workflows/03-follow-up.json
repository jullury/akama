      "parameters": {
        "jsCode": "// Build follow-up prompt and write to temp file\nconst job = $('Find Job By Reply').item.json;\nconst followUpText = $('Execute Workflow Trigger').item.json.text || '';\nconst prompt = `You are continuing work on the same repository.\n\nAdditional instructions from the user:\n${followUpText}\n\nInstructions:\n- Apply the changes requested above.\n- Commit all changes with a descriptive message.\n- Do NOT open pull requests \u2014 just commit.`;\n\nconst fs = require('fs');\nconst path = `/tmp/prompt-follow-up-${job.id}.txt`;\nfs.writeFileSync(path, prompt);\nreturn { prompt_path: path, job_id: job.id };"
      },
