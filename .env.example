# OAuth App Credentials for Build-time Injection
# Copy this file to .env and fill in your values
# .env is gitignored - never commit actual credentials

# GitHub OAuth App (https://github.com/settings/developers)
# Enable "Device Flow" in the app settings
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# GitLab Application (https://gitlab.com/-/user_settings/applications)
# Enable "Use Device Authorization Grant" in the application settings
GITLAB_CLIENT_ID=your_gitlab_client_id_here
GITLAB_CLIENT_SECRET=your_gitlab_client_secret_here
