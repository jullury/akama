# Required
N8N_ENCRYPTION_KEY=        # generate: openssl rand -hex 32
N8N_API_KEY=               # create in n8n Settings > API after first login; enables auto workflow activation
WEBHOOK_URL=               # public URL where n8n is reachable (e.g. https://akama.example.com)
ANTHROPIC_API_KEY=         # for opencode/claude with Anthropic models
OPENAI_API_KEY=            # optional: for OpenAI models

# Telegram bot token — auto-imported as n8n credential on startup (no UI setup needed)
TELEGRAM_BOT_TOKEN=        # from @BotFather

# SSH access to worker (optional - defaults to root, no password)
SSH_USER=akama             # username for SSH access
SSH_PASSWORD=changeme      # password for SSH access (required for password auth)
